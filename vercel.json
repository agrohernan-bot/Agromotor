{
  "redirects": [
    {
      "source": "/agromotor-pulverizacion.html",
      "destination": "/app.html",
      "permanent": true
    },
    {
      "source": "/cosecha-decide.html",
      "destination": "/app.html",
      "permanent": true
    },
    {
      "source": "/agromotor-alerta-sanitaria.html",
      "destination": "/app.html",
      "permanent": true
    },
    {
      "source": "/agromotor-alertas-plagas.html",
      "destination": "/app.html",
      "permanent": true
    },
    {
      "source": "/agromotor-seguimiento-v2.html",
      "destination": "/app.html",
      "permanent": true
    },
    {
      "source": "/agromotor-siembra-variable.html",
      "destination": "/app.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/js/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/css/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
